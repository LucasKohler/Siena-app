# Backend
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
SIENA__CORS__ALLOWEDORIGINS__0=http://localhost:3000
SIENA__CORS__ALLOWEDORIGINS__1=http://localhost:8081

# JWT (produção — substituir placeholders; mínimo 32 caracteres na SigningKey)
Jwt__Issuer=siena-api
Jwt__Audience=siena-mobile
Jwt__SigningKey=REPLACE_WITH_SECURE_RANDOM_KEY_MIN_32_CHARS
Jwt__AccessTokenMinutes=480

# Mobile dev (React Native Metro, future)
# EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# Published ports
API_PORT=5000
