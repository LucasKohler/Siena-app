# Copie para .env na raiz do repositório: cp .env.example .env
# Usado por docker compose (variáveis ${...} no docker-compose.yml).

# Postgres (container)
POSTGRES_PASSWORD=siena_dev
# Porta no host (5433 evita conflito com PostgreSQL instalado no Windows)
POSTGRES_PORT=5433

# API (container → host)
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Development
API_DOCKER_TARGET=development

# JWT (dev — trocar em produção)
Jwt__Issuer=siena-api-dev
Jwt__Audience=siena-mobile-dev
Jwt__SigningKey=DEV-ONLY-REPLACE-via-Jwt__SigningKey-in-production-min-32-chars
Jwt__AccessTokenMinutes=480

# CORS (opcional)
SIENA__CORS__ALLOWEDORIGINS__0=http://localhost:3000
SIENA__CORS__ALLOWEDORIGINS__1=http://localhost:8081

# Produção (docker-compose.prod.yml) — hosts permitidos pela API
# ALLOWED_HOSTS=api.siena.local;localhost

# Mobile dev (React Native / Expo) — ver também apps/mobile/.env.example
# EXPO_PUBLIC_API_URL=http://localhost:5000
